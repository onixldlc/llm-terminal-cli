{
  "name": "llm-terminal-cli",
  "version": "0.1.0",
  "description": "CLI wrapper for running Claude Code in a container (docker/podman)",
  "type": "module",
  "bin": {
    "llm-terminal-cli": "./src/llm-terminal-cli.ts"
  },
  "scripts": {
    "start": "bun run src/llm-terminal-cli.ts",
    "build": "bun build ./src/llm-terminal-cli.ts --compile --outfile dist/llm-terminal-cli",
    "build:linux-x64": "bun build ./src/llm-terminal-cli.ts --compile --target=bun-linux-x64 --outfile dist/llm-terminal-cli-linux-x64",
    "build:linux-arm64": "bun build ./src/llm-terminal-cli.ts --compile --target=bun-linux-arm64 --outfile dist/llm-terminal-cli-linux-arm64",
    "build:darwin-x64": "bun build ./src/llm-terminal-cli.ts --compile --target=bun-darwin-x64 --outfile dist/llm-terminal-cli-darwin-x64",
    "build:darwin-arm64": "bun build ./src/llm-terminal-cli.ts --compile --target=bun-darwin-arm64 --outfile dist/llm-terminal-cli-darwin-arm64",
    "build:windows-x64": "bun build ./src/llm-terminal-cli.ts --compile --target=bun-windows-x64 --outfile dist/llm-terminal-cli-windows-x64.exe",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:darwin-x64 && bun run build:darwin-arm64 && bun run build:windows-x64",
    "install-local": "bun run build && install -m 755 dist/llm-terminal-cli ~/.local/bin/llm-terminal-cli && echo 'installed to ~/.local/bin/llm-terminal-cli'"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
